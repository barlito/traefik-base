# Environment: local or production
ENV=local

# Dashboard Configuration
DASHBOARD_HOST=traefik.local.barlito.fr

# Authelia
AUTHELIA_JWT_SECRET=       # Generate with: openssl rand -base64 32
AUTHELIA_SESSION_SECRET=   # Generate with: openssl rand -base64 32
AUTHELIA_STORAGE_ENCRYPTION_KEY=  # Generate with: openssl rand -base64 32
AUTHELIA_USER_PASSWORD_HASH=  # Wrap in single quotes! Generate with: docker run --rm authelia/authelia:4 authelia crypto hash generate argon2 --password 'your-password'

# WireGuard VPN (used by docker-compose.wireguard.yml)
WG_HOST=                          # Public IP or domain of the server (required)
WG_PORT=51820
WG_DEFAULT_DNS=10.8.0.1           # 10.8.0.1 = wg-dns sidecar (resolves *.local.barlito.fr through the tunnel); use 1.1.1.1 to bypass it
WG_ALLOWED_IPS=0.0.0.0/0         # Full tunnel (or use server subnet for split tunnel)
WG_PERSISTENT_KEEPALIVE=25

# WireGuard local DNS sidecar (wg-dns)
# IP answered for *.local.barlito.fr — where VPN clients reach the dev Traefik:
# - wg-easy running ON the dev machine: 172.18.0.1 (docker_gwbridge → host ports)
# - wg-easy hosted on the prod server (deploy-vpn.yml): the WireGuard IP of the
#   dev machine's *client* profile (e.g. 10.8.0.2) — phone reaches it
#   client-to-client through the server; the dev machine must keep its VPN up.
WG_LOCAL_TARGET_IP=172.18.0.1
WG_DNS_UPSTREAM=1.1.1.1

# OVH API credentials — DNS-01 wildcard cert for *.local.barlito.fr (local only).
# Create a token at https://eu.api.ovh.com/createToken with rights:
#   GET + POST + DELETE on /domain/zone/*
# Needed at first issuance AND at every renewal (~60 days): the ACME TXT record
# is temporary, re-created at each challenge. Without creds the local stack
# still works, Traefik just falls back to the mkcert/self-signed cert.
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=

# Let's Encrypt Configuration (production only)
ACME_EMAIL=
