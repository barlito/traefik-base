# Environment: local or production
ENV=local

# Dashboard Configuration
DASHBOARD_HOST=traefik.local.barlito.fr

# Authelia
AUTHELIA_JWT_SECRET=       # Generate with: openssl rand -base64 32
AUTHELIA_SESSION_SECRET=   # Generate with: openssl rand -base64 32
AUTHELIA_STORAGE_ENCRYPTION_KEY=  # Generate with: openssl rand -base64 32
AUTHELIA_USER_PASSWORD_HASH=  # Wrap in single quotes! Generate with: docker run --rm authelia/authelia:4 authelia crypto hash generate argon2 --password 'your-password'

# WireGuard VPN (used by docker-compose.wireguard.yml)
WG_HOST=                          # Public IP or domain of the server (required)
WG_PORT=51820
WG_DEFAULT_DNS=1.1.1.1, 8.8.8.8
WG_ALLOWED_IPS=0.0.0.0/0         # Full tunnel (or use server subnet for split tunnel)
WG_PERSISTENT_KEEPALIVE=25

# Falco runtime threat detection (used by docker-compose.falco.yml — all optional)
TZ=Europe/Paris                   # Also used by fail2ban
FALCO_HOSTNAME=falco              # Hostname stamped on Falco alerts

# Let's Encrypt Configuration (production only)
ACME_EMAIL=
